{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "useDefineForClassFields": false,

    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
